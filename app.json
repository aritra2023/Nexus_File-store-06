{
    "name": "File Store Bot V2",
    "description": "Enhanced Telegram File Store Bot with 12+ features",
    "keywords": ["telegram", "files", "store", "bot", "stream"],
    "repository": "https://github.com/dengerous53/HPSuperFile_StoreBot",
    "env": {
        "API_ID": {
            "description": "Get this from my.telegram.org"
        },
        "API_HASH": {
            "description": "Get this from my.telegram.org"
        },
        "BOT_TOKEN": {
            "description": "Get this from @BotFather"
        },
        "BOT_USERNAME": {
            "description": "Your Bot Username (Without @)"
        },
        "DB_CHANNEL": {
            "description": "Channel ID for storing files. Example: -100123456789"
        },
        "BOT_OWNER": {
            "description": "Bot Owner UserID"
        },
        "DATABASE_URL": {
            "description": "MongoDB Database URI"
        },
        "LOG_CHANNEL": {
            "description": "Logs Channel ID. Example: -100123456789"
        },
        "UPDATES_CHANNEL": {
            "description": "Force Sub Channel 1 ID (Optional)",
            "required": false
        },
        "FORCE_SUB_CHANNEL_2": {
            "description": "Force Sub Channel 2 ID (Optional)",
            "required": false
        },
        "WORKER_URL": {
            "description": "Cloudflare Worker URL for share links. Leave empty for direct t.me links. Example: https://files.yoursite.workers.dev",
            "required": false
        },
        "FORCE_SUB_CHANNEL_3": {
            "description": "Force Sub Channel 3 ID (Optional)",
            "required": false
        },
        "FORCE_SUB_CHANNEL_4": {
            "description": "Force Sub Channel 4 ID (Optional)",
            "required": false
        },
        "AUTO_DELETE_TIME": {
            "description": "Auto-delete files after X seconds (0 to disable). Default: 600",
            "required": false
        },
        "CUSTOM_CAPTION": {
            "description": "Custom caption. Variables: {filename} {filesize} {caption} {mention} {username}",
            "required": false
        },
        "START_PIC": {
            "description": "URL of start message photo/image",
            "required": false
        },
        "DISABLE_CHANNEL_BUTTON": {
            "description": "Disable share button on channel files (True/False)",
            "required": false
        },
        "URL_SHORTENER": {
            "description": "Enable URL shortener (True/False)",
            "required": false
        },
        "URL_SHORTENER_API": {
            "description": "URL shortener API key",
            "required": false
        },
        "URL_SHORTENER_WEBSITE": {
            "description": "URL shortener website (e.g., gplinks.co)",
            "required": false
        },
        "TOKEN_VERIFICATION": {
            "description": "Enable token verification (True/False)",
            "required": false
        },
        "TOKEN_TIMEOUT": {
            "description": "Token validity in seconds. Default: 7200",
            "required": false
        },
        "TOKEN_SHORTENER_API": {
            "description": "Token shortener API key (can be same as URL_SHORTENER_API)",
            "required": false
        },
        "TOKEN_SHORTENER_WEBSITE": {
            "description": "Token shortener website",
            "required": false
        },
        "PROTECT_CONTENT": {
            "description": "Prevent forwarding files (True/False)",
            "required": false
        },
        "ADMINS": {
            "description": "Space-separated admin user IDs (in addition to owner)",
            "required": false
        },
        "STREAM_ENABLED": {
            "description": "Enable stream/download links (True/False)",
            "required": false
        },
        "STREAM_PORT": {
            "description": "Stream server port. Default: 8080",
            "required": false
        },
        "STREAM_FQDN": {
            "description": "Your domain for stream links (e.g., yourapp.koyeb.app)",
            "required": false
        },
        "CLONE_ENABLED": {
            "description": "Enable clone bot feature (True/False)",
            "required": false
        },
        "DEFAULT_LANGUAGE": {
            "description": "Default language: en, hi, es, fr, ar, pt, id, tr",
            "required": false
        }
    },
    "buildpacks": [
        {
            "url": "heroku/python"
        }
    ],
    "formation": {
        "worker": {
            "quantity": 1,
            "size": "eco"
        }
    }
}
